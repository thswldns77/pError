{
  "name": "perror",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.4",
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "db:generate": "pnpm --filter @perror/api prisma:generate",
    "db:migrate": "pnpm --filter @perror/api prisma:migrate",
    "dev:api": "pnpm --filter @perror/api dev",
    "dev:dashboard": "pnpm --filter @perror/dashboard dev",
    "dev:sample": "pnpm --filter @perror/sample-server dev",
    "format": "biome format --write .",
    "lint": "biome check .",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "typescript": "^5.9.3"
  }
}
